\@writefile{toc}{\contentsline {subsection}{\numberline {4.1.1}Experiment 1: Construct Validity of Pairwise Dividends}{31}{subsection.4.1.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{Test A: Detecting Artificial Redundancy}{31}{subsection.4.1.1}\protected@file@percent }
\citation{kuncheva2003measures}
\@writefile{toc}{\contentsline {subsubsection}{Test B: Agreement with Established Measures}{32}{figure.caption.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.1}{\ignorespaces Pairwise dividends for the controlled redundancy test. Darker red indicates stronger redundancy. The upper-left $3 \times 3$ block (RF and its two copies) is consistently darker than the cells involving LR and SVM, showing that the framework correctly identifies the artificial copies as more redundant. All values are negative because strong classifiers on tabular data produce universally negative dividends even across algorithm families; the \emph  {relative} darkness is the diagnostic signal.}}{33}{figure.caption.3}\protected@file@percent }
\newlabel{fig:test_a_heatmap}{{4.1}{33}{Pairwise dividends for the controlled redundancy test. Darker red indicates stronger redundancy. The upper-left $3 \times 3$ block (RF and its two copies) is consistently darker than the cells involving LR and SVM, showing that the framework correctly identifies the artificial copies as more redundant. All values are negative because strong classifiers on tabular data produce universally negative dividends even across algorithm families; the \emph {relative} darkness is the diagnostic signal}{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces Pairwise dividend matrix for the five base models used in the study. Red cells indicate redundancy (overlapping predictions); blue would indicate complementarity (models filling each other's gaps). All pairs are redundant, but to different degrees: SVM--XGB is the most redundant pair ($-0.351$), while KNN--LR is the least ($-0.249$).}}{34}{figure.caption.4}\protected@file@percent }
\newlabel{fig:dividend_heatmap}{{4.2}{34}{Pairwise dividend matrix for the five base models used in the study. Red cells indicate redundancy (overlapping predictions); blue would indicate complementarity (models filling each other's gaps). All pairs are redundant, but to different degrees: SVM--XGB is the most redundant pair ($-0.351$), while KNN--LR is the least ($-0.249$)}{figure.caption.4}{}}
\@writefile{toc}{\contentsline {subsubsection}{Test C: Smooth Response to Increasing Similarity}{34}{figure.caption.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.3}{\ignorespaces Pairwise dividend as a function of the blending coefficient $\alpha $. At $\alpha = 0$, the blended model is pure LR (different from RF), and the dividend is at its least negative value ($-0.265$). As $\alpha $ increases toward 1, the blended model becomes a copy of RF, and the dividend drops steadily to $-0.333$. The smooth, monotonic decline (Spearman $r = -0.991$) confirms that pairwise dividends track model similarity in a continuous and predictable manner.}}{35}{figure.caption.5}\protected@file@percent }
\newlabel{fig:test_c_monotonicity}{{4.3}{35}{Pairwise dividend as a function of the blending coefficient $\alpha $. At $\alpha = 0$, the blended model is pure LR (different from RF), and the dividend is at its least negative value ($-0.265$). As $\alpha $ increases toward 1, the blended model becomes a copy of RF, and the dividend drops steadily to $-0.333$. The smooth, monotonic decline (Spearman $r = -0.991$) confirms that pairwise dividends track model similarity in a continuous and predictable manner}{figure.caption.5}{}}
\@writefile{toc}{\contentsline {subsubsection}{Test D: Negative Control with Independent Models}{35}{figure.caption.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{Construct Validity Summary}{35}{figure.caption.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1.2}Diagnostic Checks}{36}{subsection.4.1.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{Decomposition Coverage}{36}{subsection.4.1.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{Monotonicity Violations and Grand Coalition Performance}{36}{subsection.4.1.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{Rank Stability}{37}{subsection.4.1.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.4}{\ignorespaces Three diagnostic checks across all 15 datasets (averaged over 5 seeds). \textbf  {Left:} Decomposition coverage is universally negative because pairwise redundancy terms outweigh singleton contributions; the 80\% threshold (red dashed line) is never met. \textbf  {Center:} Monotonicity violation rates mostly fall between 20\% and 45\%, indicating that adding a model sometimes reduces coalition performance. \textbf  {Right:} Rank stability (Spearman $r$) is uniformly 1.0 across all runs and seeds.}}{37}{figure.caption.6}\protected@file@percent }
\newlabel{fig:diagnostics}{{4.4}{37}{Three diagnostic checks across all 15 datasets (averaged over 5 seeds). \textbf {Left:} Decomposition coverage is universally negative because pairwise redundancy terms outweigh singleton contributions; the 80\% threshold (red dashed line) is never met. \textbf {Center:} Monotonicity violation rates mostly fall between 20\% and 45\%, indicating that adding a model sometimes reduces coalition performance. \textbf {Right:} Rank stability (Spearman $r$) is uniformly 1.0 across all runs and seeds}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1.3}Experiment 2: Ablation Study}{37}{subsection.4.1.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.1}{\ignorespaces Performance of all weighting variants, averaged across 15 datasets and 5 seeds. AUC-ROC measures discrimination (higher is better). Negative Brier score measures calibration quality; values closer to zero indicate better-calibrated predictions.}}{38}{table.caption.7}\protected@file@percent }
\newlabel{tab:ablation}{{4.1}{38}{Performance of all weighting variants, averaged across 15 datasets and 5 seeds. AUC-ROC measures discrimination (higher is better). Negative Brier score measures calibration quality; values closer to zero indicate better-calibrated predictions}{table.caption.7}{}}
\citation{demsar2006statistical}
\@writefile{lof}{\contentsline {figure}{\numberline {4.5}{\ignorespaces Per-dataset AUC-ROC for the five primary ablation variants. Error bars show $\pm 1$ standard deviation across five random seeds. The coopetitive variants (green and red) match or slightly exceed the Individual-Only baseline (blue) on most datasets. The Interaction-Only variant (orange) consistently underperforms across datasets.}}{39}{figure.caption.8}\protected@file@percent }
\newlabel{fig:ablation}{{4.5}{39}{Per-dataset AUC-ROC for the five primary ablation variants. Error bars show $\pm 1$ standard deviation across five random seeds. The coopetitive variants (green and red) match or slightly exceed the Individual-Only baseline (blue) on most datasets. The Interaction-Only variant (orange) consistently underperforms across datasets}{figure.caption.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1.4}Experiment 3: Benchmark Comparison}{39}{subsection.4.1.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.2}{\ignorespaces Benchmark comparison: methods ranked by how often they outperformed others across 15 datasets (lower rank is better). Mean AUC-ROC is also shown for reference.}}{40}{table.caption.9}\protected@file@percent }
\newlabel{tab:benchmark}{{4.2}{40}{Benchmark comparison: methods ranked by how often they outperformed others across 15 datasets (lower rank is better). Mean AUC-ROC is also shown for reference}{table.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.6}{\ignorespaces Average rankings across 15 datasets (lower is better). Shapley and Coopetitive-CV are nearly tied at the top, both clearly ahead of Stacking, Best Single Model, and Equal weighting. The Friedman test ($p = 0.072$) suggests meaningful differences but does not reach $p < 0.05$.}}{40}{figure.caption.10}\protected@file@percent }
\newlabel{fig:benchmark_ranks}{{4.6}{40}{Average rankings across 15 datasets (lower is better). Shapley and Coopetitive-CV are nearly tied at the top, both clearly ahead of Stacking, Best Single Model, and Equal weighting. The Friedman test ($p = 0.072$) suggests meaningful differences but does not reach $p < 0.05$}{figure.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1.5}Experiment 4: Lambda Sensitivity}{41}{subsection.4.1.5}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.3}{\ignorespaces Optimal $\lambda $ for each dataset. The wide range (0.0 to 1.5) shows that no fixed default works well everywhere.}}{41}{table.caption.11}\protected@file@percent }
\newlabel{tab:lambda}{{4.3}{41}{Optimal $\lambda $ for each dataset. The wide range (0.0 to 1.5) shows that no fixed default works well everywhere}{table.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.7}{\ignorespaces AUC-ROC as a function of $\lambda $ for all 15 datasets. The red dashed line marks the proposed default $\lambda = 0.5$. Easy datasets (top, near 1.0) are flat, as $\lambda $ does not matter when all models are already excellent. Moderate datasets (middle) peak around $\lambda = 0.5$--$0.8$. Difficult datasets (bottom) are more variable and often prefer larger $\lambda $. The non-parallel curves confirm that the optimal $\lambda $ is dataset-dependent, ruling out a universal fixed default.}}{42}{figure.caption.12}\protected@file@percent }
\newlabel{fig:lambda_sensitivity}{{4.7}{42}{AUC-ROC as a function of $\lambda $ for all 15 datasets. The red dashed line marks the proposed default $\lambda = 0.5$. Easy datasets (top, near 1.0) are flat, as $\lambda $ does not matter when all models are already excellent. Moderate datasets (middle) peak around $\lambda = 0.5$--$0.8$. Difficult datasets (bottom) are more variable and often prefer larger $\lambda $. The non-parallel curves confirm that the optimal $\lambda $ is dataset-dependent, ruling out a universal fixed default}{figure.caption.12}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1.6}Hypothesis Summary}{42}{subsection.4.1.6}\protected@file@percent }
