\@writefile{lof}{\contentsline {figure}{\numberline {4.1}{\ignorespaces Three diagnostic checks across all 15 datasets (averaged over 5 seeds). \textbf  {Left:} Decomposition coverage is universally negative because pairwise redundancy terms outweigh singleton contributions; the 80\% threshold (red dashed line) is never met. \textbf  {Center:} Monotonicity violation rates mostly fall between 20\% and 45\%, indicating that adding a model sometimes reduces coalition performance. \textbf  {Right:} Rank stability (Spearman $r$) is uniformly 1.0 across all runs and seeds.}}{35}{figure.caption.4}\protected@file@percent }
\newlabel{fig:diagnostics}{{4.1}{35}{Three diagnostic checks across all 15 datasets (averaged over 5 seeds). \textbf {Left:} Decomposition coverage is universally negative because pairwise redundancy terms outweigh singleton contributions; the 80\% threshold (red dashed line) is never met. \textbf {Center:} Monotonicity violation rates mostly fall between 20\% and 45\%, indicating that adding a model sometimes reduces coalition performance. \textbf {Right:} Rank stability (Spearman $r$) is uniformly 1.0 across all runs and seeds}{figure.caption.4}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.2}Experiment 1: Construct Validity of Pairwise Dividends}{35}{section.4.2}\protected@file@percent }
\citation{kuncheva2003measures}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.1}Test A: Detecting Artificial Redundancy}{36}{subsection.4.2.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.2}Test B: Agreement with Established Measures}{36}{subsection.4.2.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces Pairwise dividends for the controlled redundancy test. Darker red indicates stronger redundancy. The upper-left $3 \times 3$ block (RF and its two copies) is consistently darker than the cells involving LR and SVM, showing that the framework identifies the artificial copies as more redundant, as expected given the constructed ground truth. All values are negative because strong classifiers on tabular data produce universally negative dividends even across algorithm families; the \emph  {relative} darkness is the diagnostic signal.}}{37}{figure.caption.5}\protected@file@percent }
\newlabel{fig:test_a_heatmap}{{4.2}{37}{Pairwise dividends for the controlled redundancy test. Darker red indicates stronger redundancy. The upper-left $3 \times 3$ block (RF and its two copies) is consistently darker than the cells involving LR and SVM, showing that the framework identifies the artificial copies as more redundant, as expected given the constructed ground truth. All values are negative because strong classifiers on tabular data produce universally negative dividends even across algorithm families; the \emph {relative} darkness is the diagnostic signal}{figure.caption.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.3}Test C: Smooth Response to Increasing Similarity}{38}{subsection.4.2.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2.4}Test D: Negative Control with Independent Models}{38}{subsection.4.2.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.3}{\ignorespaces Pairwise dividend matrix for the five base models used in the study. Red cells indicate redundancy (overlapping predictions); blue cells (none observed in this pool) would indicate complementarity. All pairs are redundant, but to different degrees: SVM--XGB is the most redundant pair ($-0.351$), while KNN--LR is the least ($-0.249$).}}{39}{figure.caption.6}\protected@file@percent }
\newlabel{fig:dividend_heatmap}{{4.3}{39}{Pairwise dividend matrix for the five base models used in the study. Red cells indicate redundancy (overlapping predictions); blue cells (none observed in this pool) would indicate complementarity. All pairs are redundant, but to different degrees: SVM--XGB is the most redundant pair ($-0.351$), while KNN--LR is the least ($-0.249$)}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.4}{\ignorespaces Pairwise dividend as a function of the blending coefficient $\beta $. At $\beta = 0$, the blended model is pure LR (different from RF), and the dividend is at its least negative value ($-0.265$). As $\beta $ increases toward 1, the blended model becomes a copy of RF, and the dividend drops steadily to $-0.333$. The smooth, monotonic decline (Spearman $r = -0.991$) confirms that pairwise dividends track model similarity in a continuous and predictable manner.}}{39}{figure.caption.7}\protected@file@percent }
\newlabel{fig:test_c_monotonicity}{{4.4}{39}{Pairwise dividend as a function of the blending coefficient $\beta $. At $\beta = 0$, the blended model is pure LR (different from RF), and the dividend is at its least negative value ($-0.265$). As $\beta $ increases toward 1, the blended model becomes a copy of RF, and the dividend drops steadily to $-0.333$. The smooth, monotonic decline (Spearman $r = -0.991$) confirms that pairwise dividends track model similarity in a continuous and predictable manner}{figure.caption.7}{}}
